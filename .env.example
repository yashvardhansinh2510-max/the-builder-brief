# ============================================================
# THE BUILDER BRIEF — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=8080

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# --- Authentication (Clerk) ---
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# --- Frontend (Vite) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_API_URL=http://localhost:8080

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM_DOMAIN=thebuilderbrief.com

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# --- AI / Intelligence Engine ---
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# --- Security ---
# Set a strong random secret — NEVER use "changeme" in production
CRON_SECRET=generate-a-strong-random-string-here
ADMIN_TOKEN=generate-a-strong-random-string-here
ENGINE_API_KEY=generate-a-strong-random-string-here

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://thebuilderbrief.com,http://localhost:5173

# --- App URLs ---
SITE_URL=https://thebuilderbrief.com
CLIENT_URL=http://localhost:5173

# --- Supabase (for MCP tools, optional) ---
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
